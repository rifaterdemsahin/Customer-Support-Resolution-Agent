<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Act 1 — The Naive Approach | AI Agent Demo</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>❌</text></svg>">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
body{background:#0a0a0a;color:#e0e0e0;font-family:'Segoe UI',system-ui,sans-serif;width:100vw;height:100vh;overflow:hidden;display:flex;align-items:center;justify-content:center}
.stage{position:relative;width:1920px;height:1080px;overflow:hidden;background:#0a0a0a}
.scene{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;opacity:1}
.scene-bg{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;opacity:0;z-index:0}
.scene-content{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;height:100%}
.act-label{position:absolute;top:40px;left:60px;font-size:22px;color:#555;letter-spacing:4px;text-transform:uppercase}
.timeline-bar{position:absolute;bottom:0;left:0;height:4px;background:#e94560;width:0%;z-index:100}
h1{font-size:52px;font-weight:700;margin-bottom:20px}
.flash-overlay{position:absolute;top:0;left:0;width:100%;height:100%;background:#e94560;opacity:0;pointer-events:none;z-index:50}
.request-bubble{background:#1a1a2e;border:2px solid #333;border-radius:16px;padding:24px 40px;font-size:26px;margin-bottom:24px;text-align:center}
.request-bubble .icon{font-size:48px;display:block;margin-bottom:8px}
.agent-box{background:#12121f;border:2px solid #00d4aa;border-radius:20px;padding:32px 48px;display:flex;align-items:center;gap:20px;font-size:28px;transition:all 0.5s}
.agent-box.error{border-color:#e94560;background:#1a0a0f}
.agent-avatar{font-size:64px}
.policy-box{background:#111;border:1px solid #333;border-radius:12px;padding:20px 32px;margin:16px 0;font-size:22px;max-width:520px;text-align:center}
.policy-box ul{list-style:none;text-align:left}
.policy-box li{padding:6px 0;color:#888}
.policy-box li.covered::before{content:"✅ ";color:#00cc66}
.policy-box li.gap::before{content:"❓ ";color:#e94560}
.result-badge{font-size:100px;margin:16px 0}
.result-label{font-size:32px;font-weight:700}
.result-label.error{color:#e94560}
.policy-gap-banner{background:#1a0a0f;border:2px solid #e94560;border-radius:12px;padding:16px 32px;font-size:28px;color:#e94560;font-weight:700}
.overlay-box{background:rgba(10,10,10,0.85);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border-radius:16px;padding:24px 40px}
.subtitle-bar{position:absolute;bottom:120px;left:50%;transform:translateX(-50%);z-index:80;opacity:0;border-radius:14px;overflow:hidden}
.subtitle-bg{background:#e94560;padding:18px 36px;border-radius:14px}
.subtitle-text{font-size:30px;font-weight:700;color:#fff;white-space:nowrap;letter-spacing:1px;font-family:'Segoe UI',system-ui,sans-serif}
.agent-infographic,.gray-area-overlay{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:60;opacity:0;border-radius:16px}
.agent-infographic{max-width:700px;width:60%;border:2px solid rgba(0,212,170,0.25);box-shadow:0 0 40px rgba(0,212,170,0.15)}
.gray-area-overlay{max-width:650px;width:55%;border:2px solid rgba(233,69,96,0.3);box-shadow:0 0 50px rgba(233,69,96,0.18)}
.agent-infographic img,.gray-area-overlay img{width:100%;height:auto;display:block;border-radius:14px}
.nav-bar{position:absolute;top:40px;right:60px;z-index:100;display:flex;gap:12px}
.nav-link{padding:8px 18px;border-radius:8px;font-size:16px;font-weight:700;text-decoration:none;transition:all 0.3s}
.nav-link.next{background:rgba(0,204,102,0.15);color:#00cc66;border:1px solid rgba(0,204,102,0.3)}
.nav-link.home{background:rgba(0,212,170,0.1);color:#00d4aa;border:1px solid rgba(0,212,170,0.2)}
.nav-link:hover{filter:brightness(1.4)}
.audio-toggle{padding:8px 14px;border-radius:8px;font-size:16px;font-weight:700;cursor:pointer;background:rgba(0,212,170,0.1);color:#00d4aa;border:1px solid rgba(0,212,170,0.2);transition:all 0.3s;user-select:none;line-height:1}
.audio-toggle.muted{background:rgba(233,69,96,0.1);color:#e94560;border:1px solid rgba(233,69,96,0.2)}
.problem-card{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:90;opacity:0;text-align:center;max-width:1200px;width:85%;background:rgba(10,10,10,0.92);border:3px solid #00d4aa;border-radius:24px;padding:44px 60px;box-shadow:0 0 60px rgba(0,212,170,0.12),inset 0 0 60px rgba(0,212,170,0.04)}
.problem-card .problem-title{font-size:56px;font-weight:800;color:#00d4aa;margin-bottom:20px;line-height:1.3}
.problem-card .problem-subtitle{font-size:28px;color:#999;line-height:1.5;margin-bottom:30px}
.problem-card .problem-rule{display:inline-block;background:rgba(233,69,96,0.15);border:1px solid #e94560;border-radius:10px;padding:12px 28px;font-size:24px;color:#e94560}
.escalation-svg-wrap{margin:24px 0 12px 0;opacity:0}
.escalation-path{stroke:#00cc66;stroke-width:3;stroke-dasharray:200;stroke-dashoffset:200;fill:none;stroke-linecap:round}

.debug-panel{position:absolute;bottom:0;left:0;width:100%;z-index:200;background:rgba(10,10,10,0.97);border-top:1px solid rgba(0,212,170,0.3);height:180px;transform:translateY(calc(100% - 34px));transition:transform 0.35s;display:flex;flex-direction:column}
.debug-panel.open{transform:translateY(0)}
.debug-toggle{display:flex;align-items:center;gap:10px;padding:6px 16px;cursor:pointer;background:rgba(0,212,170,0.06);font-size:12px;color:#e94560;font-weight:700;letter-spacing:1px;text-transform:uppercase;user-select:none;flex-shrink:0;min-height:34px}
.debug-toggle .toggle-arrow{font-size:10px;transition:transform 0.3s}
.debug-panel.open .debug-toggle .toggle-arrow{transform:rotate(180deg)}
.debug-status{margin-left:auto;display:flex;gap:10px;align-items:center}
.status-badge{font-size:10px;padding:2px 8px;border-radius:8px}
.status-badge.imgs{background:rgba(0,212,170,0.12);color:#00d4aa}
.status-badge.audio{background:rgba(0,204,102,0.12);color:#00cc66}
.status-badge.events{background:rgba(255,170,0,0.12);color:#ffaa00;margin-left:auto}
.debug-body{display:flex;gap:0;flex:1;overflow:hidden;border-top:1px solid rgba(255,255,255,0.04)}
.debug-timeline{flex:0 0 340px;overflow-y:auto;padding:6px 10px;border-right:1px solid rgba(255,255,255,0.05);font-family:'SF Mono','Fira Code',monospace;font-size:11px}
.debug-timeline .tl-entry{display:flex;gap:6px;padding:2px 0;border-bottom:1px solid rgba(255,255,255,0.02);align-items:flex-start;cursor:pointer}
.tl-dot{width:7px;height:7px;border-radius:50%;margin-top:5px;flex-shrink:0}
.tl-dot.info{background:#00d4aa}.tl-dot.artifact{background:#00cc66}.tl-dot.error{background:#e94560}.tl-dot.transition{background:#ffaa00}.tl-dot.image{background:#ff66aa}.tl-dot.subtitle{background:#8888ff}
.debug-timeline .tl-time{color:#00d4aa;min-width:36px;font-weight:700}
.debug-timeline .tl-id{color:#555;font-size:9px;min-width:22px;font-weight:700;flex-shrink:0}
.debug-timeline .tl-msg{color:#aaa;word-break:break-all}
.debug-explain{flex:1;overflow-y:auto;padding:8px 14px;display:flex;flex-direction:column;gap:8px}
.debug-explain h4{font-size:13px;color:#e94560;letter-spacing:1px;text-transform:uppercase}
.debug-explain p{font-size:13px;color:#888;line-height:1.6;margin:0}
.env-links{display:flex;gap:5px;margin-left:16px;font-size:11px;align-items:center}
.env-links a{color:#666;text-decoration:none;padding:2px 10px;border-radius:6px;border:1px solid rgba(255,255,255,0.06);transition:all 0.2s}
.env-links a:hover{color:#00d4aa;border-color:rgba(0,212,170,0.35);background:rgba(0,212,170,0.06)}
.env-links .sep{color:#444;margin:0 1px}
.dbg-btn{padding:3px 9px;border-radius:5px;font-size:13px;cursor:pointer;background:rgba(0,212,170,0.06);color:#777;border:1px solid rgba(255,255,255,0.06);transition:all 0.2s;user-select:none;line-height:1.2}
.dbg-btn:hover{color:#00d4aa;border-color:rgba(0,212,170,0.25);background:rgba(0,212,170,0.1)}
.dbg-btn.paused{background:rgba(233,69,96,0.15);color:#e94560;border-color:rgba(233,69,96,0.3)}
.dbg-btn.copied{background:rgba(0,204,102,0.15);color:#00cc66;border-color:rgba(0,204,102,0.3)}
.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.88);z-index:999;display:none;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal-box{background:#0d0d0d;border:2px solid #00d4aa;border-radius:16px;width:92%;max-width:960px;max-height:85vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 0 60px rgba(0,212,170,0.12)}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid rgba(0,212,170,0.12)}
.modal-header h3{color:#00d4aa;font-size:20px;margin:0;letter-spacing:1px}
.modal-close{cursor:pointer;color:#666;font-size:28px;transition:color 0.2s;line-height:1}
.modal-close:hover{color:#e94560}
.modal-body{flex:1;overflow-y:auto;padding:20px 24px;color:#bbb;font-size:13px;line-height:1.7;white-space:pre-wrap;font-family:'SF Mono','Fira Code',monospace}
.modal-footer{display:flex;gap:10px;padding:14px 24px;border-top:1px solid rgba(0,212,170,0.12)}
</style>
</head>
<body>
<div class="stage" id="stage">

  <div class="flash-overlay" id="flash"></div>
  <div class="nav-bar">
    <a class="nav-link home" href="index.html">🏠 Storyboard</a>
    <a class="nav-link next" href="act2.html">Act 2 ▶</a>
    <span class="audio-toggle" id="audio-toggle" title="Toggle audio">🔊</span>
  </div>

  <div class="subtitle-bar" id="subtitle-bar">
    <div class="subtitle-bg"><span class="subtitle-text" id="subtitle-text"></span></div>
  </div>

  <div class="problem-card" id="problem-card">
    <div class="problem-title">The AI Agent Policy Gap Problem</div>
    <div class="problem-subtitle">
      A customer requests a competitor price match.<br>
      Internal policy covers own-site drops within 14 days —<br>
      but is <span style="color:#e94560;font-weight:700;">silent on competitor pricing</span>.
    </div>
    <div class="problem-rule">⚠️ Unmapped Policy Gap — No Deterministic Rule</div>
    <div class="escalation-svg-wrap" id="escalation-svg-wrap">
      <svg width="740" height="200" viewBox="0 0 740 200" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(80,50)">
          <line x1="40" y1="0" x2="40" y2="18" stroke="#00d4aa" stroke-width="3" stroke-linecap="round"/>
          <circle cx="40" cy="-4" r="6" fill="none" stroke="#00d4aa" stroke-width="2"/>
          <rect x="12" y="18" width="56" height="44" rx="8" fill="none" stroke="#00d4aa" stroke-width="3"/>
          <circle cx="30" cy="37" r="5" fill="#00d4aa"/>
          <circle cx="50" cy="37" r="5" fill="#00d4aa"/>
          <rect x="26" y="47" width="28" height="4" rx="2" fill="#00d4aa"/>
          <circle cx="40" cy="-4" r="10" fill="#00d4aa" opacity="0.15"><animate attributeName="r" values="10;14;10" dur="2s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.15;0.05;0.15" dur="2s" repeatCount="indefinite"/></circle>
          <rect x="4" y="68" width="72" height="50" rx="10" fill="none" stroke="#00d4aa" stroke-width="3"/>
          <line x1="40" y1="78" x2="40" y2="108" stroke="#00d4aa" stroke-width="2" opacity="0.5"/>
        </g>
        <text x="120" y="185" fill="#00d4aa" font-size="20" font-weight="700" text-anchor="middle">AI Agent</text>
        <text x="120" y="170" fill="#555" font-size="14" text-anchor="middle">Autonomous</text>
        <path class="escalation-path" id="escalation-path" d="M 210,110 C 280,110 280,80 340,80 C 400,80 400,110 470,110"/>
        <polygon id="escalation-arrowhead" points="470,103 490,110 470,117" fill="#00cc66" opacity="0"/>
        <circle class="escalation-dot" id="dot1" cx="260" cy="100" r="4" fill="#00cc66" opacity="0"/>
        <circle class="escalation-dot" id="dot2" cx="310" cy="82" r="4" fill="#00cc66" opacity="0"/>
        <circle class="escalation-dot" id="dot3" cx="370" cy="82" r="4" fill="#00cc66" opacity="0"/>
        <circle class="escalation-dot" id="dot4" cx="420" cy="105" r="4" fill="#00cc66" opacity="0"/>
        <text x="350" y="65" fill="#888" font-size="14" text-anchor="middle" opacity="0" id="flow-label">escalation</text>
        <g transform="translate(540,50)">
          <circle cx="40" cy="20" r="18" fill="none" stroke="#00cc66" stroke-width="3"/>
          <circle cx="34" cy="18" r="3" fill="#00cc66"/>
          <circle cx="46" cy="18" r="3" fill="#00cc66"/>
          <path d="M 30,28 Q 40,36 50,28" fill="none" stroke="#00cc66" stroke-width="2" stroke-linecap="round"/>
          <rect x="16" y="42" width="48" height="50" rx="10" fill="none" stroke="#00cc66" stroke-width="3"/>
          <line x1="16" y1="52" x2="4" y2="78" stroke="#00cc66" stroke-width="3" stroke-linecap="round"/>
          <line x1="64" y1="52" x2="76" y2="78" stroke="#00cc66" stroke-width="3" stroke-linecap="round"/>
          <circle cx="40" cy="20" r="28" fill="#00cc66" opacity="0.08"><animate attributeName="r" values="28;34;28" dur="2.5s" repeatCount="indefinite"/></circle>
        </g>
        <text x="580" y="170" fill="#666" font-size="14" text-anchor="middle">Expert</text>
        <text x="580" y="190" fill="#00cc66" font-size="20" font-weight="700" text-anchor="middle">Human Agent</text>
      </svg>
    </div>
  </div>

  <div class="scene" id="scene1">
    <img class="scene-bg" id="scene1-bg" src="generated-images/2026-07-07T09-10-41Z/act1-request.png" alt="">
    <div class="act-label">Act 1 — The Naive Approach</div>
    <div class="scene-content">
    <div id="s1-request" style="opacity:0;">
      <div class="request-bubble overlay-box"><span class="icon">💰</span>"I found this cheaper at CompetitorCo. Can you match their price?"</div>
    </div>
    <div id="s1-agent" style="opacity:0;display:flex;flex-direction:column;align-items:center;gap:20px">
      <div class="agent-box" id="s1-agent-box"><span class="agent-avatar">🤖</span><span>AI Agent — Analyzing request...</span></div>
    </div>
    <div class="agent-infographic" id="agent-infographic">
      <img src="infographic/image.png" alt="Agent workflow"><div style="text-align:center;color:#666;font-size:14px;margin-top:4px">get_customer() → lookup_order()</div>
    </div>
    <div id="s1-policy" style="opacity:0;display:flex;flex-direction:column;align-items:center;">
      <div class="policy-box">
        <div style="font-size:18px;color:#666;margin-bottom:10px">📋 Policy Rules Check:</div>
        <ul>
          <li class="covered">Own-site price drop (within 14 days)</li>
          <li class="covered">Bundle discount with existing subscription</li>
          <li class="gap">Competitor price matching</li>
          <li class="covered">Coupon stacking (max 2)</li>
        </ul>
      </div>
    </div>
    <div id="s1-gap" style="opacity:0;"><div class="policy-gap-banner">⚠️ Policy Gap — No Rule Found</div></div>
    <div class="gray-area-overlay" id="gray-area-overlay">
      <img src="infographic/gray area.jpeg" alt="Gray area"><div style="text-align:center;color:#e94560;font-size:14px;margin-top:4px;font-weight:700">Policy Gap — No Deterministic Rule Exists</div>
    </div>
    <div id="s1-guess" style="opacity:0;text-align:center">
      <div style="font-size:96px;margin-bottom:10px">🤖💭</div><div style="font-size:26px;color:#888;margin-bottom:14px">"I'll just... figure it out"</div>
    </div>
    <div id="s1-result" style="opacity:0;text-align:center">
      <div class="result-badge">❌</div><div class="result-label error">Guessed Wrong — Unauthorized 15% Discount Applied</div>
      <div style="font-size:22px;color:#e94560;margin-top:10px">Financial loss: -$47.85</div>
    </div>
    </div>
  </div>

  <div class="timeline-bar" id="timeline"></div>

  <audio id="audio-act1" preload="auto" src="generated-audio/2026-07-07T09-28-54Z/act1-narration.mp3"></audio>

  <div class="debug-panel" id="debug-panel">
    <div class="debug-toggle" id="debug-toggle">
      <span class="toggle-arrow">▲</span> 🐞 Act 1 Debug
      <span class="env-links">
        <a href="act1.html" title="Local Act 1">🏠 Local</a><span class="sep">|</span>
        <a href="https://rifaterdemsahin.github.io/Customer-Support-Resolution-Agent/act1.html" title="Cloud / GitHub Pages">🌐 Cloud</a>
      </span>
      <span class="dbg-btn" id="dbg-pause" title="Pause / Play animation">⏸</span>
      <span class="dbg-btn" id="dbg-copy" title="Copy debug log to clipboard">📋</span>
      <span class="dbg-btn" id="dbg-script" title="Open docs/script.md">📜</span>
      <span class="debug-status">
        <span class="status-badge imgs" id="status-scene" style="background:rgba(233,69,96,0.2);color:#e94560;margin-right:8px">📍 Scene 1/3: Problem Card</span>
        <span class="status-badge imgs" id="status-imgs">🖼 0/0</span>
        <span class="status-badge audio" id="status-audio">🔊 0/0</span>
        <span class="status-badge events" id="status-events">📋 0</span>
      </span>
    </div>
    <div class="debug-body">
      <div class="debug-timeline" id="debug-timeline"></div>
      <div class="debug-explain" id="debug-explain">
        <h4>📖 Act 1 Events</h4><p>Click any event to see its explanation.</p>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script>
(function() {
  var tl = gsap.timeline({ defaults: { ease: "power3.inOut" } });
  var subText = document.getElementById('subtitle-text');
  var subBar = document.getElementById('subtitle-bar');
  var audioEl = document.getElementById('audio-act1');
  var audioMuted = false;
  document.getElementById('audio-toggle').addEventListener('click', function() {
    audioMuted = !audioMuted;
    var btn = document.getElementById('audio-toggle');
    if (audioMuted) { btn.textContent = '🔇'; btn.className = 'audio-toggle muted'; audioEl.pause(); }
    else { btn.textContent = '🔊'; btn.className = 'audio-toggle'; }
  });
  var allEvents = [], imgLoad = 0, imgTotal = 0, audLoad = 0, audTotal = 0, evtSeq = 0;
  var timelineList = document.getElementById('debug-timeline');
  var explainH4 = document.getElementById('debug-explain').querySelector('h4');
  var explainP = document.getElementById('debug-explain').querySelector('p');
  var stImgs = document.getElementById('status-imgs');
  var stAud = document.getElementById('status-audio');

  function addEntry(time, msg, explain, cls) {
    evtSeq++; var eid = 'E'+evtSeq;
    allEvents.push({t:time,m:msg,e:explain||msg,c:cls||'info',id:eid});
    var e = document.createElement('div'); e.className = 'tl-entry'; e.style.cursor = 'pointer';
    e.innerHTML = '<span class="tl-dot '+(cls||'info')+'"></span><span class="tl-id">'+eid+'</span><span class="tl-time">'+time+'s</span><span class="tl-msg">'+msg.slice(0,50)+'</span>';
    e.addEventListener('click',function(){explainH4.textContent='📖 '+eid+' — '+time+'s '+((cls||'info').toUpperCase());explainP.innerHTML='<strong>'+msg+'</strong><br><br>'+(explain||msg)});
    timelineList.appendChild(e); timelineList.scrollTop = timelineList.scrollHeight;
    document.getElementById('status-events').textContent = '📋 '+allEvents.length;
  }
  function logEvent(msg, at, explain, cls) {
    tl.call(function(){var t=tl.time().toFixed(1);console.log('['+t+'s] '+msg);addEntry(t,msg,explain,cls)},null,at);
  }
  function showSubtitle(text, at, dur) { dur=dur||1.8;
    tl.call(function(){subBar.className='subtitle-bar';subText.textContent=text},null,at);
    tl.fromTo(subBar,{opacity:1,clipPath:'inset(0 100% 0 0)'},{clipPath:'inset(0 0% 0 0)',duration:dur,ease:'steps('+Math.min(text.length,30)+')'},at+'+=0');
    tl.to(subBar,{opacity:0,duration:0.6},at+'+= '+(dur+3.5));
  }
  function playAudio(at) {
    tl.call(function(){if(audioMuted)return;try{audioEl.currentTime=0;audioEl.play().catch(function(){})}catch(e){}},null,at);
  }
  function showScene(num, name, at) {
    var entry = null;
    tl.call(function(){
      document.getElementById('status-scene').textContent = '📍 Scene '+num+'/3: '+name;
      entry = addEntry(tl.time().toFixed(1),'📍 Scene '+num+'/3: '+name,'Scene transition','info');
    },null,at);
  }

  // Debug toggle
  document.getElementById('debug-toggle').addEventListener('click',function(){document.getElementById('debug-panel').classList.toggle('open')});

  // Pause/play button
  var isPaused = false;
  document.getElementById('dbg-pause').addEventListener('click',function(e){e.stopPropagation();
    isPaused = !isPaused; var btn = document.getElementById('dbg-pause');
    if (isPaused) { tl.pause(); btn.textContent = '▶'; btn.className = 'dbg-btn paused'; }
    else { tl.play(); btn.textContent = '⏸'; btn.className = 'dbg-btn'; }
  });

  // Copy debug log
  document.getElementById('dbg-copy').addEventListener('click',function(e){e.stopPropagation();
    var lines = allEvents.map(function(ev){return '['+ev.id+'] '+ev.t+'s '+ev.m;}).join('\n');
    navigator.clipboard.writeText(lines).then(function(){
      var btn = document.getElementById('dbg-copy'); btn.textContent = '✓'; btn.className = 'dbg-btn copied';
      setTimeout(function(){btn.textContent = '📋'; btn.className = 'dbg-btn';}, 1200);
    }).catch(function(){}); 
  });

  // Open script modal
  document.getElementById('dbg-script').addEventListener('click',function(e){e.stopPropagation();
    var modal = document.getElementById('script-modal'); modal.classList.add('open');
    var body = document.getElementById('modal-body');
    if (!body.dataset.loaded) {
      fetch('docs/script.md').then(function(r){return r.text()}).then(function(t){
        body.textContent = t; body.dataset.loaded = '1';
      })["catch"](function(){body.textContent = 'Failed to load script.md';});
    }
  });
  document.getElementById('modal-close').addEventListener('click',function(){
    document.getElementById('script-modal').classList.remove('open');
  });
  document.getElementById('script-modal').addEventListener('click',function(e){
    if (e.target === this) this.classList.remove('open');
  });
  document.getElementById('modal-copy').addEventListener('click',function(){
    navigator.clipboard.writeText(document.getElementById('modal-body').textContent).then(function(){
      var b = document.getElementById('modal-copy'); b.textContent = '\u2713 Copied!'; b.className = 'dbg-btn copied';
      setTimeout(function(){b.textContent = '\uD83D\uDCCB Copy Script'; b.className = 'dbg-btn';}, 1500);
    })["catch"](function(){});
  });

  // Track artifacts
  document.querySelectorAll('img').forEach(function(img,i){
    imgTotal++; var nm=(img.src.split('/').pop()||'img-'+i).split('?')[0];
    img.addEventListener('load',function(){imgLoad++;addEntry('0.0','🖼 '+nm,'Loaded','image');stImgs.textContent='🖼 '+imgLoad+'/'+imgTotal});
    img.addEventListener('error',function(){imgLoad++;addEntry('0.0','🖼 FAIL: '+nm,'','error')});
    if(img.complete&&img.naturalWidth>0){imgLoad++;addEntry('0.0','🖼 Cached: '+nm,'','image')}
  });
  document.querySelectorAll('audio').forEach(function(a){
    audTotal++; var nm=a.src.split('/').pop()||'audio';
    a.addEventListener('loadeddata',function(){audLoad++;addEntry('0.0','🔊 '+nm,'Loaded','artifact');stAud.textContent='🔊 '+audLoad+'/'+audTotal});
    a.addEventListener('error',function(){audLoad++;addEntry('0.0','🔊 FAIL: '+nm,'','error')});
    if(a.readyState>=2){audLoad++;addEntry('0.0','🔊 Cached: '+nm,'','artifact')}
  });
  setTimeout(function(){stImgs.textContent='🖼 '+imgLoad+'/'+imgTotal;stAud.textContent='🔊 '+audLoad+'/'+audTotal},100);

  addEntry('0.0','Act 1: Naive Approach (8s)','8-second premise-focused act','info');
  addEntry('0.0','GSAP '+gsap.version+' loaded','GreenSock animation engine','artifact');

  /* ============ ACT 1 TIMELINE (8s) — 3 scenes ============ */
  // DESIGN RULES (docs/rules.md): 3s min audience hold per event, 3.5s subtitle dwell
  showScene(1,'Problem Card',0);
  tl.to("#scene1-bg",{opacity:0.35,duration:1},0);
  logEvent('Act 1 started','+=0');

  // Problem card
  tl.to("#problem-card",{opacity:1,scale:1.05,duration:0.6},"+=0.2");
  tl.to("#problem-card",{scale:1,duration:0.4});
  tl.to("#escalation-svg-wrap",{opacity:1,duration:0.5},"-=0.2");
  tl.to("#escalation-path",{strokeDashoffset:0,duration:1.2,ease:"power3.inOut"},"-=0.1");
  tl.to("#escalation-arrowhead",{opacity:1,duration:0.3},"-=0.6");
  tl.to("#dot1",{opacity:1,duration:0.2},"-=0.8");tl.to("#dot2",{opacity:1,duration:0.2},"-=0.6");
  tl.to("#dot3",{opacity:1,duration:0.2},"-=0.4");tl.to("#dot4",{opacity:1,duration:0.2},"-=0.2");
  tl.to("#flow-label",{opacity:1,duration:0.4},"-=0.1");
  showSubtitle("AI agents face uncertainty when policy rules don't cover every scenario.",'+=0.5',2.0);
  logEvent('Problem card displayed','+=0.5');

  tl.to("#problem-card",{opacity:1,duration:2.0});
  tl.to("#problem-card",{opacity:0,y:-30,duration:0.5},"+=0.3");
  showScene(2,'Policy Gap','+=0');
  showSubtitle("Customer requests a competitor price match.",'+=0',1.6);
  logEvent('Problem card dismissed','+=0');

  tl.to("#s1-request",{opacity:1,duration:0.6},"+=0.2");
  logEvent('Request bubble appears','+=0');
  tl.to("#s1-agent",{opacity:1,duration:0.5},"+=0.3");
  tl.to("#s1-agent-box",{scale:1.02,duration:0.3,repeat:1,yoyo:true});
  showSubtitle("AI agent checks internal policy rules...",'+=0.2',1.5);
  logEvent('Agent appears','+=0');

  tl.to("#agent-infographic",{opacity:1,scale:1,duration:0.5},"+=0.2");
  tl.to("#agent-infographic",{opacity:1,duration:1.0});
  logEvent('Infographic shown','+=0','get_customer() + lookup_order()');
  tl.to("#agent-infographic",{opacity:0,duration:0.3},"+=0.2");

  tl.to("#s1-policy",{opacity:1,duration:0.6},"+=0.4");
  tl.to("#s1-policy li.gap",{color:"#e94560",fontWeight:"bold",duration:0.5},"+=0.5");
  showSubtitle("Policy gap found: competitor price matching has no rule.",'+=0.5',1.8);
  logEvent('Policy gap highlighted','+=0');

  tl.to("#s1-gap",{opacity:1,scale:1,duration:0.5});
  logEvent('Gap banner shown','+=0');
  tl.to("#gray-area-overlay",{opacity:1,duration:0.5},"+=0.2");
  tl.to("#gray-area-overlay",{opacity:1,duration:2.0});
  logEvent('Gray area overlay shown','+=0');
  tl.to("#gray-area-overlay",{opacity:0,duration:0.3},"+=0.2");

  tl.to("#s1-guess",{opacity:1,duration:0.5},"+=0.4");
  showSubtitle("No matching rule. Agent guesses — applies 15% discount.",'+=0.3',1.8);
  logEvent('Agent guesses','+=0');

  tl.to("#flash",{opacity:0.4,duration:0.15},"+=0.3");
  tl.to("#flash",{opacity:0,duration:0.4});
  showScene(3,'Error Outcome','+=0');
  tl.to("#s1-agent-box",{className:"agent-box error",duration:0.2},"-=0.5");
  logEvent('Red flash — error','+=0');

  tl.to("#s1-guess",{opacity:0,duration:0.2},"+=0.2");
  tl.to("#s1-result",{opacity:1,scale:1.1,duration:0.4});
  tl.to("#s1-result",{scale:1,duration:0.3});
  showSubtitle("Financial loss: unauthorized discount applied.",'+=0.2',1.5);
  logEvent('Error result — financial loss','+=0');

  playAudio('+=0.3');
  showSubtitle("When guidelines are silent, autonomous agents risk financial errors.",'+=0.3',2.2);

  tl.to("#scene1",{opacity:0,duration:0.5},"+=1.0");
  logEvent('Act 1 complete','+=0','Transition to Act 2','transition');

  // Timeline bar
  tl.to("#timeline",{width:"100%",duration:8,ease:"none"},0);
  tl.to({},{duration:1});
  tl.eventCallback("onComplete",function(){console.log('[8s] Act 1 loop');tl.restart(true,false)});
})();
</script>
</body>
</html>
